# ---- Zentro backend environment variables ----

# Port the server listens on (Render sets this automatically; 3000 for local).
PORT=3000

# Path to the yt-dlp binary.
#   Local Windows dev: leave as "yt-dlp" if it's on your PATH, or an absolute
#   path like C:\tools\yt-dlp.exe
#   On Render: ./bin/yt-dlp  (downloaded by build.sh)
YTDLP_PATH=yt-dlp

# Folder (or binary path) containing ffmpeg/ffprobe.
#   Local: leave blank if ffmpeg is on your PATH.
#   On Render: ./bin
FFMPEG_LOCATION=

# ---- Supabase (optional but recommended for history + caching) ----
# From Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Use the SERVICE ROLE key (server-side only, never ship it in the mobile app)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_BUCKET=media-cache

# Set to "true" to upload downloads to Supabase Storage and serve cached
# re-downloads instantly (uses your 1GB free quota).
ENABLE_CACHE=false
