{
  "expo": {
    "name": "Zentro",
    "slug": "zentro",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "zentro",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0B0B12",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.zentro.app",
      "infoPlist": {
        "NSPhotoLibraryAddUsageDescription": "Zentro saves your downloaded videos and photos to your Camera Roll.",
        "NSPhotoLibraryUsageDescription": "Zentro needs access to save and manage downloaded media in your library."
      }
    },
    "android": {
      "package": "com.zentro.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B0B12"
      },
      "permissions": ["READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-media-library",
        {
          "photosPermission": "Zentro saves downloaded media to your Camera Roll.",
          "savePhotosPermission": "Zentro saves downloaded media to your Camera Roll.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ]
  }
}
