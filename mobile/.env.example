# ---- Zentro mobile environment variables ----
# Expo only exposes variables prefixed with EXPO_PUBLIC_ to the app at runtime.

# Base URL of your backend.
#   Local testing (Expo Go on your iPhone, same Wi-Fi as your PC):
#     EXPO_PUBLIC_API_URL=http://192.168.1.23:3000      <- your PC's LAN IP
#   After deploying to Render:
#     EXPO_PUBLIC_API_URL=https://zentro-backend.onrender.com
EXPO_PUBLIC_API_URL=http://192.168.1.23:3000
